    "@types/hast": "^3.0.4",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/unist": "^3.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.2.2",
    "vite": "^6.4.2"
  }
