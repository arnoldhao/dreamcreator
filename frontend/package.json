{
  "name": "dreamcreator",
  "private": true,
  "version": "dev",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=24.11.1 <25",
    "bun": "1.3.5"
  },
  "scripts": {
    "dev": "vite",
    "audit:i18n": "node scripts/audit-i18n.mjs",
    "audit:i18n:strict": "node scripts/audit-i18n.mjs --strict",
    "audit:dto": "node scripts/audit-dto.mjs",
    "audit:structure": "node scripts/audit-structure.mjs",
    "audit:redundancy": "node scripts/audit-redundancy.mjs",
    "audit:all": "bun run audit:i18n:strict && bun run audit:dto && bun run audit:structure && bun run audit:redundancy",
    "test:telemetry": "bun test src/shared/telemetry/manager.test.ts",
    "test:stream-parser": "bun test src/shared/assistant/stream-parser.test.ts",
    "test:workspace-preview": "bun scripts/run-workspace-preview-tests.mjs",
    "build:dev": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build --minify false --mode development",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build --mode production",
    "preview": "vite preview"
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.17",
    "@assistant-ui/react-streamdown": "^0.1.2",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@pierre/diffs": "^1.0.10",
    "@pixiv/three-vrm": "^3.0.0",
    "@pixiv/three-vrm-animation": "^3.0.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
