    "@wavesurfer/react": "^1.0.12",
    "assistant-stream": "^0.3.2",
    "beautiful-mermaid": "^0.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "eventsource-parser": "^3.0.6",
    "immer": "^11.1.3",
    "katex": "^0.16.11",
    "lucide-react": "^0.575.0",
    "media-captions": "1.0.4",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "recharts": "^2.12.7",
    "rehype-katex": "^7.0.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^1.6.0",
    "simple-icons": "^16.6.1",
    "tailwind-merge": "^2.2.1",
    "three": "^0.161.0",
    "tw-shimmer": "^0.4.7",
    "unified": "^11.0.5",
    "video.js": "^8.23.7",
    "wavesurfer.js": "^7.12.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
